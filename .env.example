# --- GoodGame chat ---
GG_LOGIN=
GG_PASSWORD=
# id самого бота (число из ответа chatlogin) — чтобы игнорировать свои сообщения.
# Можно оставить пустым: бот подставит user_id, полученный при логине.
GG_USER_ID=
# id канала (число из URL стрима, напр. goodgame.ru/CHANNEL_KEY -> числовой id)
GG_CHANNEL_ID=
# Необязательно, только для логов
GG_CHANNEL_KEY=
# id администратора для !списать / !начислить (ваш user_id на GoodGame)
GG_ADMIN_USER_ID=

# --- Локальный сервер для OBS (один порт: HTTP-раздача player.html + WebSocket) ---
OBS_WS_HOST=127.0.0.1
OBS_WS_PORT=8765

# --- Очередь / модерация ---
MAX_QUEUE_SIZE=50
# Лимит длительности трека (сек). Проверяется на стороне плеера через getDuration().
MAX_DURATION_SEC=300
# Watchdog: если трек не завершился за (MAX_DURATION_SEC + запас), снять принудительно.
TRACK_WATCHDOG_EXTRA_SEC=60
# Антиспам: минимум секунд между !sr от одного пользователя (0 = выключено)
USER_COOLDOWN_SEC=0

# --- TODO: pre-check длительности/18+/стоп-слов через YouTube Data API ---
# YOUTUBE_API_KEY=

# --- Коллекционные карты / альбом ---
ALBUM_LINK_SECRET=
SITE_BASE_URL=https://klon008.github.io/princtascdwk/
# Опционально: явный git-репо артов/лора (иначе вывод из SITE_BASE_URL → github.com/klon008/princtascdwk).
# CARD_ASSETS_REPO_URL=https://github.com/klon008/princtascdwk.git
# sync: scripts\sync-card-assets.ps1 (также из update.ps1).
# Токен CloudPub (обязателен для автозапуска clo из бота). Не коммить реальное значение.
CLO_TOKEN=
# Путь к clo.exe (по умолчанию tools/clo/clo.exe в корне репо)
# CLO_EXE_PATH=
# Только для тестов БЕЗ clo: задай публичный URL вручную (или http://127.0.0.1:18770 чтобы отключить туннель).
# Если задано — бот НЕ запускает clo.exe.
CLO_PUBLIC_URL=
